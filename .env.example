DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Google OAuth for Auth.js / NextAuth
AUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Optional local development shim. If set, the app will use this user
# instead of requiring a real Google sign-in.
# DEV_USER_EMAIL=dev@example.com
# DEV_USER_NAME=Brackeroni Dev

# Gemini-backed extraction endpoint.
GEMINI_API_KEY=replace-with-gemini-api-key
# GEMINI_MODEL=gemini-3.1-flash-lite
